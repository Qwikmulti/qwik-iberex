
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PropertyStatus {
  ACTIVE
  SELLING_FAST
  FOR_SALE
  FOR_RENT
  HERITAGE
  NEW_CONSTRUCTION
  SOLD
  ARCHIVED
}

enum PropertyType {
  DETACH
  SEMI_DETACH
  PENTHOUSE
  ESTATE
  TERRACE
  APARTMENT
  VILLA
}

enum UserRole {
  ADMIN
  AGENT
  USER
}

enum BlogCategory {
  BUY
  SELL
  TRENDS
  BUYING_TIPS
  LIFESTYLE
  INTERIOR_DESIGN
  INVESTMENT
  MARKET_TRENDS
}

enum InquiryStatus {
  NEW
  READ
  ASSIGNED
  REPLIED
  CLOSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  phone         String?
  bio           String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  inquiries   Inquiry[]
  blogPosts   BlogPost[]
  assignedInquiries Inquiry[] @relation("AssignedAgent")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Neighborhood {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String  @db.Text
  tagline     String?
  imageUrl    String?
  city        String  @default("Abuja")
  state       String  @default("FCT")
  country     String  @default("Nigeria")
  featured    Boolean @default(false)
  sortOrder   Int     @default(0)

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("neighborhoods")
}

model Property {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  tagline        String?
  description    String         @db.Text
  narrative      String?        @db.Text  // Architectural narrative
  status         PropertyStatus @default(ACTIVE)
  type           PropertyType   @default(DETACH)

  // Pricing
  askingPrice    Decimal        @db.Decimal(15, 2)
  currency       String         @default("NGN")
  pricePerSqft   Decimal?       @db.Decimal(10, 2)

  // Specs
  bedrooms       Int
  bathrooms      Int
  sqft           Int
  garages        Int?
  floors         Int?
  yearBuilt      Int?
  landSize       Int?

  // Location
  address        String
  city           String         @default("Abuja")
  state          String         @default("FCT")
  country        String         @default("Nigeria")
  latitude       Float?
  longitude      Float?
  neighborhoodId String?

  // Flags
  featured       Boolean        @default(false)
  published      Boolean        @default(true)
  exclusive      Boolean        @default(false)

  // Media
  coverImageUrl  String?
  videoUrl       String?

  // SEO
  metaTitle      String?
  metaDescription String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  neighborhood   Neighborhood?  @relation(fields: [neighborhoodId], references: [id])
  images         PropertyImage[]
  amenities      PropertyAmenity[]
  inquiries      Inquiry[]
  nearbyPlaces   NearbyPlace[]

  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  altText     String?
  caption     String?
  isCover     Boolean  @default(false)
  sortOrder   Int      @default(0)
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Amenity {
  id         String @id @default(cuid())
  name       String @unique
  slug       String @unique
  icon       String? // lucide icon name
  category   String?

  properties PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model NearbyPlace {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  distance    String   // e.g. "5 mins", "2 km"
  type        String?  // golf, business, hotel
  sortOrder   Int      @default(0)

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("nearby_places")
}

model BlogPost {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  excerpt     String       @db.Text
  content     String       @db.Text  // HTML from Tiptap
  category    BlogCategory @default(TRENDS)
  coverImage  String?
  authorId    String
  readTime    Int          @default(5)  // minutes
  featured    Boolean      @default(false)
  published   Boolean      @default(false)
  publishedAt DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

model Inquiry {
  id               String        @id @default(cuid())
  fullName         String
  email            String
  phone            String?
  message          String        @db.Text
  propertyId       String?
  propertyTitle    String?       // Snapshot at time of inquiry
  status           InquiryStatus @default(NEW)
  userId           String?
  assignedAgentId  String?
  notes            String?       @db.Text  // Internal agent notes
  source           String?       // contact-form, property-page, tour-request

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  property         Property?     @relation(fields: [propertyId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
  assignedAgent    User?         @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  @@map("inquiries")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  source    String?
  createdAt DateTime @default(now())

  @@map("subscribers")
}

model MediaAsset {
  id          String   @id @default(cuid())
  filename    String
  url         String
  mimeType    String
  size        Int      // bytes
  width       Int?
  height      Int?
  altText     String?
  tags        String[] @default([])
  uploadedBy  String?
  bucket      String   @default("property-images")
  path        String

  createdAt   DateTime @default(now())

  @@map("media_assets")
}
